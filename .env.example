# ---- Copy to .env and fill in. Never commit .env ----

# Postgres
POSTGRES_USER=vp
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=video_processing
# Connection string used by the app (host is the compose service name)
DATABASE_URL=postgres://vp:change-me-postgres@postgres:5432/video_processing

# Redis (BullMQ broker)
REDIS_URL=redis://redis:6379

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=vpminio
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
# Public base URL the browser/CDN uses to fetch HLS segments (set to your domain in prod)
MINIO_PUBLIC_URL=http://localhost:9000

# Bucket names
BUCKET_INPUTS=inputs
BUCKET_OUTPUTS=outputs
BUCKET_THUMBS=thumbnails

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# How long signed private-stream URLs stay valid (seconds)
SIGNED_URL_TTL=3600

# ---- Two-factor (email OTP) ----
# 2FA is ON by default. Set to false to issue tokens without an email code.
TWO_FACTOR_ENABLED=true
# SMTP for delivering OTP emails. Leave blank to run in "dev mode": codes are
# logged by the API and shown in the UI instead of being emailed.
# For Gmail: host=smtp.gmail.com, port=465, user=you@gmail.com, pass=APP PASSWORD
# (create one at https://myaccount.google.com/apppasswords).
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Zorvid <no-reply@zorvid.archilect.in>

# ---- Optional Google sign-in ----
# Set BOTH to the same OAuth client ID to enable the "Continue with Google"
# button. Leave blank to hide it. Create one at https://console.cloud.google.com
# (Credentials -> OAuth client ID -> Web application).
GOOGLE_CLIENT_ID=
# Frontend build-time copy of the same client ID (Vite needs the VITE_ prefix).
VITE_GOOGLE_CLIENT_ID=

# API
API_PORT=3000
# Max upload size in bytes (default 2 GiB)
MAX_UPLOAD_BYTES=2147483648

# Worker
# How many transcode jobs a single worker process runs at once
WORKER_CONCURRENCY=2
# Total seconds of video each user may upload across their whole library.
# Enforced after probing: an upload that pushes a user over this is failed and
# its files deleted. Default 600 = 10 minutes.
MAX_VIDEO_SECONDS_PER_USER=600
# Uploaded videos are auto-deleted this many days after creation (rows + files).
VIDEO_RETENTION_DAYS=2
# How often (ms) the worker runs its maintenance sweep (retention). Default 1h.
MAINTENANCE_INTERVAL_MS=3600000

# ---- Published host ports (override if a port is already in use) ----
# Only the gateway (HTTP_HOST_PORT) needs to be reachable; the rest are for
# local inspection. The app itself talks over the internal compose network.
HTTP_HOST_PORT=8080
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
